DATABASE_URL="postgresql://USER:SENHA@localhost:5432/appcontagem"
NODE_ENV=development
PORT=3333
API_PREFIX=/api/v1

# Em produção, gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET e JWT_REFRESH_SECRET DEVEM ser diferentes (em produção, mínimo 64 chars)
JWT_SECRET=gere_uma_chave_de_pelo_menos_32_caracteres_aqui
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=gere_outra_chave_diferente_de_pelo_menos_32_caracteres_aqui
JWT_REFRESH_EXPIRES_IN=30d

# Em produção: lista de domínios separados por vírgula. NUNCA use "*".
# Ex: CORS_ORIGIN=https://app.pizzadofabio.com.br,https://admin.pizzadofabio.com.br
CORS_ORIGIN=http://localhost:8081

PERDA_THRESHOLD=5
CONTAGEM_THRESHOLD=2

# Colibri POS — deixe vazio se não usa
COLIBRI_BASE_URL=https://cloud.colibricloud.com
COLIBRI_CLIENT_ID=
COLIBRI_STORE_ID=

# Operação
HORARIO_INICIO_TURNO=17
HORARIO_FECHAMENTO_AUTO=4
DIVERGENCIA_LEVE_UNIDADES=2
DIVERGENCIA_LEVE_PERCENT=5

# Sentry (free tier: sentry.io) — deixe vazio pra desativar error tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Webhook de alertas (Discord/Slack/Telegram) — deixe vazio pra desativar
# Discord: https://discord.com/api/webhooks/ID/TOKEN
# Slack: https://hooks.slack.com/services/...
# Telegram: https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>&text=
ALERTA_WEBHOOK_URL=
